rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /stadiums/default {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stadiums/default/notifications/{notificationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
